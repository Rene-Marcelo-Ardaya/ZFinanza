# =============================================
# Configuration for React Base Project
# =============================================
#
# Copy this file to .env.local (your local machine only)
#

# API Configuration
# The base URL for your API
VITE_API_URL=/api

# Proxy DEV for /api -> server
# Defaults:
# - target: http://localhost:8000
# - rewrite: /api
#
# If you want to use a remote server:
# VITE_API_PROXY_TARGET=https://your-server.com
# VITE_API_PROXY_REWRITE_BASE=/api

VITE_API_PROXY_TARGET=http://localhost:8000
VITE_API_PROXY_REWRITE_BASE=/api

# Application Configuration
VITE_APP_NAME=React Base Project
VITE_APP_SHORT_NAME=ReactBase
VITE_APP_DESCRIPTION=React + Vite Base Project with Design System

# Base Path Configuration
# Set the base path for your application (e.g., /app/, /dashboard/)
# Leave empty for root deployment
VITE_BASE_PATH=/

# Theme Configuration
# Default theme to use (see src/theme/tokens/ for available themes)
VITE_DEFAULT_THEME=kaizen

# Feature Flags
# Enable/disable features
VITE_UI_REFRESH_V1=1
